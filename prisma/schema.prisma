generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  phone          String?
  role           String    @default("CLIENT")
  isActive       Boolean   @default(true)
  referralCode   String?   @unique
  referredById   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  referredBy       User?          @relation("ReferralInviter", fields: [referredById], references: [id], onDelete: SetNull)
  invitedUsers     User[]         @relation("ReferralInviter")
  accounts          Account[]
  sessions          Session[]
  shops             Shop[]
  addresses         Address[]
  orders            Order[]
  reviews           Review[]
  cart              Cart?
  wishlists         Wishlist[]
  notifications     Notification[]
  shopFollows       ShopFollow[]
  auditLogs         AuditLog[]
  couponsCreated    Coupon[]
  couponUsages      CouponUsage[]
  pushSubscriptions PushSubscription[]
  loyaltyPoints     LoyaltyPoint[]
  referralsMade     Referral[]     @relation("ReferralReferrer")
  referralsReceived Referral[]     @relation("ReferralReferee")

  @@index([email])
  @@index([role])
  @@index([referralCode])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String
  firstName  String
  lastName   String
  address    String
  city       String
  state      String?
  postalCode String
  country    String
  phone      String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Shop {
  id              String    @id @default(cuid())
  userId          String
  name            String
  slug            String    @unique
  description     String?
  logo            String?
  banner          String?
  phone           String?
  email           String?
  address         String?
  city            String?
  country         String?
  showPublicContact Boolean   @default(false)
  storeType       String?   @default("PHYSICAL")
  commissionRate  Float     @default(5.0)
  isActive        Boolean   @default(true)
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet          Wallet?
  products        Product[]
  orders          Order[]
  payouts         VendorPayout[]
  commissions     Commission[]
  reviews         Review[]
  followers       ShopFollow[]
  flashSales      FlashSale[]
  storeConfig     StoreConfig?
  coupons         Coupon[]

  @@index([slug])
  @@index([isActive])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  image       String?
  icon        String?
  productType String?
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]

  @@index([slug])
}

model Product {
  id          String         @id @default(cuid())
  shopId      String
  categoryId  String?
  name        String
  slug        String         @unique
  description String?
  productType String         @default("PHYSICAL")
  price       Float
  comparePrice Float?
  discountPercent Float?
  sku         String?
  stock       Int            @default(0)
  weight      Float?
  isActive    Boolean        @default(true)
  isFeatured  Boolean        @default(false)
  isHidden    Boolean        @default(false)
  videoUrl    String?
  seoTitle    String?
  seoDescription String?
  seoKeywords String?
  brand       String?
  dimensions  String?
  ctaText     String?
  ctaColor    String?
  postPurchaseInstructions String?
  warranty    String?
  returnPolicy String?
  status     String         @default("draft")
  requiresShippingAddress Boolean @default(true)
  metadata    Json?
  avgRating   Float          @default(0)
  reviewCount Int            @default(0)
  soldCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category    Category?      @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  digitalFile DigitalFile?
  physicalOpt PhysicalOption?
  orderItems  OrderItem[]
  reviews     Review[]
  cartItems   CartItem[]
  wishlists   Wishlist[]
  tags        ProductTag[]
  variants    ProductVariant[]
  flashSales  FlashSale[]

  @@index([shopId])
  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@index([price])
}

model DigitalFile {
  id              String   @id @default(cuid())
  productId       String   @unique
  fileUrl         String?
  externalUrl     String?
  fileName        String?
  fileSize        Int?
  fileType        String?
  maxDownloads    Int?
  downloadCount   Int      @default(0)
  storagePath     String?
  storageBucket   String?  @default("nova-uploads")
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PhysicalOption {
  id              String   @id @default(cuid())
  productId       String   @unique
  shippingEnabled Boolean  @default(true)
  shippingCost    Float?
  shippingCountries String?
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductTag {
  id        String  @id @default(cuid())
  productId String
  tag       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([tag])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int     @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  variantId String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  shopId          String
  addressId       String?
  subtotal        Float
  shippingFee     Float       @default(0)
  tax             Float       @default(0)
  discount        Float       @default(0)
  total           Float
  status          String      @default("PENDING")
  paymentMethod   String
  paymentStatus   String      @default("PENDING")
  paymentId       String?
  trackingNumber  String?
  notes           String?
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  shop        Shop          @relation(fields: [shopId], references: [id])
  address     Address?      @relation(fields: [addressId], references: [id])
  items       OrderItem[]
  payment     Payment?
  commission  Commission?
  couponUsages CouponUsage[]

  @@index([userId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  price     Float
  quantity  Int
  image     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  amount        Float
  currency      String   @default("XOF")
  method        String
  status        String   @default("PENDING")
  transactionId String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order   @relation(fields: [orderId], references: [id])
}

model Commission {
  id        String   @id @default(cuid())
  orderId   String   @unique
  shopId    String
  amount    Float
  rate      Float
  status    String   @default("PENDING")
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  shop  Shop  @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

model VendorPayout {
  id            String   @id @default(cuid())
  shopId        String
  amount        Float
  method        String
  accountInfo   Json
  status        String   @default("PENDING")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

model Wallet {
  id              String   @id @default(cuid())
  shopId          String   @unique
  balance         Float    @default(0)
  pendingBalance  Float    @default(0)
  currency        String   @default("XOF")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  shopId     String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([shopId])
}

model ShopFollow {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model SiteSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String?
  price     Float
  stock     Int      @default(0)
  image     String?
  options   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  wishlists  Wishlist[]
  orderItems OrderItem[]

  @@index([productId])
}

model FlashSale {
  id            String   @id @default(cuid())
  shopId        String
  productId     String
  title         String
  salePrice     Float
  originalPrice Float
  stock         Int      @default(0)
  soldCount     Int      @default(0)
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([productId])
  @@index([isActive, startsAt, endsAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entityType  String
  entityId    String?
  beforeState Json?
  afterState  Json?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model PlatformConfig {
  id    String @id @default("singleton")
  key   String @unique
  value Json
  updatedAt DateTime @updatedAt
}

model StoreConfig {
  id       String @id @default(cuid())
  shopId   String @unique
  primaryColor   String @default("#4f46e5")
  secondaryColor String @default("#7c3aed")
  fontFamily     String @default("Inter")
  theme          String @default("moderne")
  darkMode       Boolean @default(false)
  showFeatured   Boolean @default(true)
  showCategories Boolean @default(true)
  showReviews    Boolean @default(true)
  showBanners    Boolean @default(true)
  sectionOrder   Json @default("[\"featured\",\"categories\",\"reviews\",\"banners\"]")
  currency       String @default("XOF")
  globalDiscount Float @default(0)
  couponsEnabled Boolean @default(true)
  whatsapp       String?
  instagram      String?
  facebook       String?
  emailSupport   String?
  shippingZones  Json @default("[]")
  defaultShippingCost Float @default(0)
  shippingDelay  String?
  physicalEnabled  Boolean @default(true)
  digitalEnabled   Boolean @default(true)
  serviceEnabled   Boolean @default(false)
  stockRules       Json @default("{}")
  variantEnabled   Boolean @default(true)
  aiDescriptions   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  ticketId    String   @db.Text
  senderId    String?  @db.Text
  senderRole  String   @default("USER") @db.Text
  content     String   @db.Text
  contentType String   @default("text") @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    String    @default("PERCENTAGE")
  discountValue   Float
  minOrderAmount  Float?
  maxDiscount     Float?
  usageLimit      Int?
  usedCount       Int       @default(0)
  perUserLimit    Int?      @default(1)
  shopId          String?
  productIds      Json?
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shop    Shop?  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])
  usages  CouponUsage[]

  @@index([code])
  @@index([shopId])
  @@index([isActive])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String
  amount    Float
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([couponId, orderId])
  @@index([couponId])
  @@index([userId])
}

model PushSubscription {
  id            String   @id @default(cuid())
  userId        String
  endpoint      String
  p256dh        String
  auth          String
  userAgent     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([endpoint])
}

model LoyaltyPoint {
  id          String   @id @default(cuid())
  userId      String
  shopId      String
  orderId     String?
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shopId])
  @@index([userId, shopId])
}

model LoyaltyConfig {
  id              String   @id @default(cuid())
  shopId          String   @unique
  isEnabled       Boolean  @default(true)
  pointsPerCurrency Float  @default(1.0)
  redeemRate      Float    @default(100.0)
  minRedeem       Int      @default(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopId])
}

model ReferralConfig {
  id                  String   @id @default(cuid())
  rewardAmount        Float    @default(500)
  rewardType          String   @default("CREDIT")
  minPurchaseAmount   Float    @default(0)
  maxReferralsPerUser Int      @default(50)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  refereeId      String
  code           String
  status         String    @default("PENDING")
  rewardAmount   Float     @default(0)
  rewardGivenAt  DateTime?
  createdAt      DateTime  @default(now())

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([refereeId])
  @@index([code])
  @@index([status])
}
