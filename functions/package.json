    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.13.2",
    "next": "16.2.10"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
