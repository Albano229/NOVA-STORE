  "faq": {
    "title": "Frequently Asked Questions",
    "q1": {
      "q": "How to create a shop?",
      "a": "Click \"Create a shop\", choose seller role, fill in the form and your shop is ready in minutes."
    },
    "q2": {
      "q": "How to receive money?",
      "a": "Payments are sent directly to your Stripe, PayPal or Mobile Money account. You can request a withdrawal anytime from your dashboard."
    },
    "q3": {
      "q": "Is it secure?",
      "a": "Yes! We use Stripe for bank payments and bank-level security protocols. Your data and your customers' data are protected."
    },
    "q4": {
      "q": "Can I sell from my phone?",
      "a": "Absolutely. NOVA is 100% responsive. You can manage your shop, add products and track orders from your smartphone."
    },
    "q5": {
      "q": "What are the fees?",
      "a": "NOVA charges a 10% commission on each sale. You can also choose a subscription plan for advanced features."
    }
  },
